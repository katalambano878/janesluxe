# Database (Supabase)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Payments — Paystack
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=YOUR_PAYSTACK_PUBLIC_KEY
PAYSTACK_SECRET_KEY=YOUR_PAYSTACK_SECRET_KEY

# Payments — Moolre (optional)
MOOLRE_API_KEY=YOUR_MOOLRE_API_KEY
MOOLRE_MERCHANT_ID=YOUR_MOOLRE_MERCHANT_ID

# Email (Resend)
RESEND_API_KEY=YOUR_RESEND_API_KEY
RESEND_FROM_EMAIL=noreply@yourdomain.com
EMAIL_FROM=YOUR_BRAND_NAME <noreply@yourdomain.com>
ADMIN_EMAIL=admin@yourdomain.com

# SMS (optional)
SMS_API_KEY=YOUR_SMS_API_KEY
SMS_SENDER_ID=YOUR_SMS_SENDER

# App identity
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_SITE_NAME=YOUR_BRAND_NAME
NEXT_PUBLIC_SITE_DESCRIPTION=YOUR_PROJECT_DESCRIPTION
NEXT_PUBLIC_CONTACT_EMAIL=hello@yourdomain.com
NEXT_PUBLIC_CONTACT_PHONE=YOUR_PHONE_NUMBER
NEXT_PUBLIC_CONTACT_PHONE_DISPLAY=YOUR_PHONE_NUMBER
NEXT_PUBLIC_SOCIAL_INSTAGRAM=@YOUR_HANDLE
NEXT_PUBLIC_WHATSAPP_URL=YOUR_WHATSAPP_URL
NEXT_PUBLIC_WHATSAPP_GROUP_URL=YOUR_WHATSAPP_GROUP_URL

# Security
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=YOUR_RECAPTCHA_SITE_KEY
RECAPTCHA_SECRET_KEY=YOUR_RECAPTCHA_SECRET_KEY

# Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=YOUR_GA4_MEASUREMENT_ID
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=YOUR_GOOGLE_VERIFICATION_CODE

# AI chat (optional)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# Cron / maintenance
CRON_SECRET=YOUR_CRON_SECRET
MAINTENANCE_MODE=false

# Admin bootstrap (scripts/create-admin.mjs)
ADMIN_PASSWORD=YOUR_SECURE_ADMIN_PASSWORD
